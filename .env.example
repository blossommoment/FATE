DEEPSEEK_API_KEY=your_deepseek_api_key
# 可选：若机器全局已有同名 DEEPSEEK_API_KEY（会顶掉 .env 文件），改用 FATE_ 前缀，项目优先读它
# FATE_DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.siliconflow.cn/v1
DEEPSEEK_MODEL=deepseek-ai/DeepSeek-V3.2
# 付费解锁：解锁码/token 签名密钥（openssl rand -hex 32；换值会使已售未兑的码失效）
UNLOCK_SECRET=your_unlock_secret
# 可选：解锁码售卖页（发卡平台/爱发电链接），配了前端解锁卡才显示购买入口
# NEXT_PUBLIC_UNLOCK_SHOP_URL=https://...
