# AI
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.siliconflow.cn/v1
DEEPSEEK_MODEL=deepseek-ai/DeepSeek-V3.2

# Private report URLs and signed browser entitlements. Use independent 32+ byte secrets.
REPORT_STATE_SECRET=
ENTITLEMENT_SECRET=
REPORT_STATE_TTL_SECONDS=21600
ENTITLEMENT_TTL_DAYS=3650

# Optional Agent API. Completed Agent reports stay in process memory only, then expire.
AGENT_API_KEY=
AGENT_REPORT_TTL_SECONDS=600

# Durable one-time-code and paid-order storage: Vercel KV or Upstash Redis REST.
KV_REST_API_URL=
KV_REST_API_TOKEN=
ENTITLEMENT_KV_PREFIX=fate:entitlement:v1

# Optional hosted Checkout. Do not set these until your approved payment provider account is ready.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PERSONAL_FULL=
STRIPE_PRICE_DUO_FULL=

# PDF runtime fonts. Required on hosts that do not include a Chinese font.
FATE_PDF_FONT_HEI=
FATE_PDF_FONT_KAI=
